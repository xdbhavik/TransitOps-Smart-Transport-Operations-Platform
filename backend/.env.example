# Server
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/TransitDB?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# JWT
JWT_SECRET=9f8a7b6c5d4e3f2g1h0i9j8k7l6m5n4o
